{
  "version": 8,
  "name": "Misy — charte funnel (OSM vectoriel)",
  "metadata": {
    "comment": "Réplique le style Google custom du funnel: routes lavande #A6B5DE, eau #ADD4F5, POI masqués, fond #E5E9EC. Schéma OpenMapTiles (sortie Planetiler). La source 'openmaptiles' est fournie par PmTilesVectorTileProvider côté Flutter."
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "pmtiles://madagascar.pmtiles"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#E5E9EC" }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": { "fill-color": "#DDE3E0", "fill-opacity": 0.6 }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": { "fill-color": "#DCE6DC", "fill-opacity": 0.7 }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": { "fill-color": "#ADD4F5" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": { "line-color": "#ADD4F5", "line-width": 1.2 }
    },
    {
      "id": "road-local",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service", "track"],
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": {
          "base": 1.2,
          "stops": [[12, 0.6], [14, 1.5], [16, 4], [18, 10]]
        }
      }
    },
    {
      "id": "road-arterial",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "secondary", "tertiary", "primary"],
      "paint": {
        "line-color": "#BCC5E8",
        "line-width": {
          "base": 1.2,
          "stops": [[10, 1], [13, 2.5], [16, 7], [18, 16]]
        }
      }
    },
    {
      "id": "road-highway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway", "trunk"],
      "paint": {
        "line-color": "#A6B5DE",
        "line-width": {
          "base": 1.2,
          "stops": [[8, 1.5], [12, 3.5], [16, 9], [18, 20]]
        }
      }
    },
    {
      "id": "boundary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["<=", "admin_level", 4],
      "paint": { "line-color": "#C2C9D2", "line-width": 1, "line-dasharray": [3, 2] }
    },
    {
      "id": "road-name",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "transportation_name",
      "minzoom": 13,
      "layout": {
        "symbol-placement": "line",
        "text-field": "{name}",
        "text-size": 11
      },
      "paint": {
        "text-color": "#7A7A7A",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["in", "class", "city", "town", "village"],
      "layout": {
        "text-field": "{name}",
        "text-size": {
          "base": 1.2,
          "stops": [[8, 11], [12, 15], [16, 20]]
        }
      },
      "paint": {
        "text-color": "#5A5A5A",
        "text-halo-color": "#FFFFFF",
        "text-halo-width": 1.8
      }
    }
  ]
}
